// SQLite schema for local development
// For PostgreSQL production schema, see schema.postgresql.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String?
  firstName    String
  lastName     String
  phone        String?
  googleId     String?   @unique
  role         String    @default("USER")  // "USER" | "ADMIN"
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  bookings     Booking[]
}

model Property {
  id          String    @id @default(cuid())
  title       String
  location    String
  price       Int
  rating      Float    @default(0)
  reviews     Int      @default(0)
  bedrooms    Int
  bathrooms   Int
  area        Int
  description String
  imagesJson  String    @default("[]")     // JSON array of image URLs
  amenitiesJson String @default("[]")     // JSON array
  nearbyJson  String    @default("[]")     // JSON array
  type        String                       // "apartment" | "studio" | "penthouse"
  available   Boolean  @default(true)
  featured    Boolean  @default(false)
  icalToken   String?  @unique              // token for the outbound iCal feed URL
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  bookings        Booking[]
  calendarSources CalendarSource[]
  calendarBlocks  CalendarBlock[]
  priceRules      PriceRule[]
}

// External iCal feeds (Airbnb, Booking.com, VRBO, ...) imported per property
model CalendarSource {
  id           String          @id @default(cuid())
  propertyId   String
  property     Property        @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  name         String                              // "Airbnb", "Booking.com", ...
  url          String                              // external iCal/ICS URL
  lastSyncedAt DateTime?
  lastStatus   String?                             // "OK (n events)" | "ERROR: ..."
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  blocks       CalendarBlock[]
}

// Blocked date ranges: imported from a CalendarSource, or created manually by admin
model CalendarBlock {
  id         String          @id @default(cuid())
  propertyId String
  property   Property        @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  sourceId   String?                              // null = manual block
  source     CalendarSource? @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  uid        String?                              // iCal UID for dedupe
  summary    String?
  start      DateTime
  end        DateTime
  createdAt  DateTime        @default(now())

  @@index([propertyId])
  @@index([sourceId])
}

// Seasonal / date-range nightly price overrides; base Property.price is the fallback
model PriceRule {
  id         String   @id @default(cuid())
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  name       String?                              // "Peak season", "Weekends", ...
  start      DateTime
  end        DateTime
  price      Int                                  // nightly price override (KES)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([propertyId])
}

model Booking {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id])
  propertyId      String
  property        Property  @relation(fields: [propertyId], references: [id])
  checkIn         DateTime
  checkOut        DateTime
  guests          Int
  bedOption       String?   // "1bed" | "2bed"
  checkInTime     String?
  specialRequests String?
  paymentMethod   String    // "card" | "mpesa" | "bank"
  status          String    @default("PENDING")  // "PENDING" | "CONFIRMED" | "CANCELLED"
  subtotal        Int
  cleaningFee     Int       @default(1500)
  serviceFee      Int
  promoCodeId     String?
  promoCode       PromoCode? @relation(fields: [promoCodeId], references: [id])
  discountAmount  Int       @default(0)
  total           Int
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model PromoCode {
  id               String    @id @default(cuid())
  code             String    @unique
  discountPercent  Int
  maxDiscount      Int?
  minBookingAmount Int?
  validFrom        DateTime
  validUntil       DateTime
  maxUses          Int?
  currentUses      Int       @default(0)
  active           Boolean   @default(true)
  createdBy        String
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  bookings         Booking[]
}
