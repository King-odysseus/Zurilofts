// PostgreSQL schema for Railway production
// Uses native PostgreSQL features: enums, arrays (String[]), uuid()

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  HOST
  ADMIN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String?
  firstName    String
  lastName     String
  phone        String?
  googleId     String?   @unique
  avatar       String?         // profile image path
  role         Role      @default(USER)
  suspended    Boolean   @default(false)     // admin-disabled: blocks login + hides host listings
  bankName       String?       // Host bank name
  bankAccountNo  String?       // Host 10-digit Kenyan account number
  bankCode       String?       // Paystack bank code
  payoutFrequency String?      // "weekly" | "biweekly" | "monthly"
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  bookings     Booking[]
  reviews      Review[]
  favorites    Favorite[]
  messages     Message[]
  properties   Property[]
  payouts      Payout[]
  wallet       HostWallet?
}

model Property {
  id          String    @id @default(uuid())
  hostId      String?                        // user who owns/manages this property
  host        User?     @relation(fields: [hostId], references: [id])
  title       String
  location    String
  price         Int
  price1Bed     Int?                              // nightly price for 1-bed option
  price2Bed     Int?                              // nightly price for 2-bed option
  bathrooms1Bed Int?                              // bathroom count for 1-bed listing
  bathrooms2Bed Int?                              // bathroom count for 2-bed listing
  rating        Float    @default(0)
  reviews     Int      @default(0)
  bedrooms    Int
  bathrooms   Int
  area        Int
  neighborhood String?                  // Kilimani | Westlands | Karen | Gigiri | Lavington
  lat          Float?                   // map coordinate
  lng          Float?                   // map coordinate
  description String
  imagesJson   String    @default("[]")
  amenitiesJson String   @default("[]")
  nearbyJson   String    @default("[]")
  type        String
  available   Boolean  @default(true)
  featured    Boolean  @default(false)
  icalToken   String?  @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  bookings        Booking[]
  calendarSources CalendarSource[]
  calendarBlocks  CalendarBlock[]
  priceRules      PriceRule[]
  guestReviews    Review[]
  favoritedBy     Favorite[]

  @@index([hostId])
}

// External iCal feeds (Airbnb, Booking.com, VRBO, ...) imported per property
model CalendarSource {
  id           String          @id @default(uuid())
  propertyId   String
  property     Property        @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  name         String
  url          String
  lastSyncedAt DateTime?
  lastStatus   String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  blocks       CalendarBlock[]
}

// Blocked date ranges: imported from a CalendarSource, or created manually by admin
model CalendarBlock {
  id         String          @id @default(uuid())
  propertyId String
  property   Property        @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  sourceId   String?
  source     CalendarSource? @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  uid        String?
  summary    String?
  start      DateTime
  end        DateTime
  createdAt  DateTime        @default(now())

  @@index([propertyId])
  @@index([sourceId])
}

// Seasonal / date-range nightly price overrides; base Property.price is the fallback
model PriceRule {
  id         String   @id @default(uuid())
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  name       String?
  start      DateTime
  end        DateTime
  price      Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([propertyId])
}

model Booking {
  id              String        @id @default(uuid())
  userId          String
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  propertyId      String
  property        Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  checkIn         DateTime
  checkOut        DateTime
  guests          Int
  bedOption       String?
  checkInTime     String?
  checkOutTime    String?
  specialRequests String?
  additionalGuestsJson String?
  paymentMethod   String
  status          BookingStatus @default(PENDING)
  subtotal        Int
  cleaningFee     Int           @default(1500)
  serviceFee      Int
  lateCheckoutFee Int           @default(0)
  promoCodeId     String?
  promoCode       PromoCode?    @relation(fields: [promoCodeId], references: [id])
  discountAmount  Int           @default(0)
  total           Int
  paymentReference String?  @unique
  paymentChannel   String?
  paymentGateway   String?
  paidAt           DateTime?
  hostNetAmount    Int?
  withholdingTax   Int?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  review          Review?
  payoutBookings  PayoutBooking[]
}

// Post-stay guest review: star rating + a private note for the admin on how to
// improve. One review per booking.
model Review {
  id          String   @id @default(uuid())
  bookingId   String   @unique
  booking     Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  propertyId  String
  property    Property @relation(fields: [propertyId], references: [id])
  rating      Int
  satisfaction String? // "happy" | "neutral" | "unhappy"
  privateNote String?
  hidden      Boolean   @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([propertyId])
}

model Favorite {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([userId, propertyId])
  @@index([userId])
}

model Message {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  senderRole  String
  body        String
  readByAdmin Boolean  @default(false)
  readByUser  Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([userId])
}

model AppSetting {
  id    String @id @default(uuid())
  key   String @unique
  value String
}

model PromoCode {
  id               String    @id @default(uuid())
  code             String    @unique
  discountPercent  Int
  maxDiscount      Int?
  minBookingAmount Int?
  validFrom        DateTime
  validUntil       DateTime
  maxUses          Int?
  currentUses      Int      @default(0)
  active           Boolean  @default(true)
  createdBy        String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  bookings         Booking[]
}

model BlogPost {
  id          String    @id @default(uuid())
  title       String
  slug        String    @unique
  excerpt     String?
  body        String
  coverImage  String?
  published   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model PushSubscription {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint   String   @unique
  keys       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId])
}

model HostWallet {
  id            String   @id @default(uuid())
  hostId        String   @unique
  host          User     @relation(fields: [hostId], references: [id])
  balance       Int      @default(0)
  totalEarned   Int      @default(0)
  totalPaidOut  Int      @default(0)
  lastPayoutAt  DateTime?
  nextPayoutAt  DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Payout {
  id            String   @id @default(uuid())
  hostId        String
  host          User     @relation(fields: [hostId], references: [id])
  amount        Int
  transferRef   String?  @unique
  recipientCode String?
  status        String   @default("PENDING")
  failureReason String?
  initiatedBy   String?
  bookingsCount Int      @default(0)
  completedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  bookings      PayoutBooking[]
}

model PayoutBooking {
  id        String  @id @default(uuid())
  payoutId  String
  payout    Payout @relation(fields: [payoutId], references: [id], onDelete: Cascade)
  bookingId String
  booking   Booking @relation(fields: [bookingId], references: [id])
  amount    Int

  @@unique([payoutId, bookingId])
  @@index([bookingId])
}

model PaymentLog {
  id        String   @id @default(uuid())
  bookingId String?
  event     String
  reference String?
  payload   String?
  createdAt DateTime @default(now())
}
