# Database (provided by Railway PostgreSQL plugin)
DATABASE_URL="postgresql://postgres:password@localhost:5432/zurilofts?schema=public"

# JWT Secrets — use strong random values in production
JWT_ACCESS_SECRET="generate-a-strong-random-secret-here-min-32-chars"
JWT_REFRESH_SECRET="generate-another-strong-random-secret-min-32-chars"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# Google OAuth (https://console.cloud.google.com)
GOOGLE_CLIENT_ID="your-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-your-client-secret"
GOOGLE_CALLBACK_URL="http://localhost:3000/api/auth/google/callback"

# Server
PORT=3000
NODE_ENV="development"
CLIENT_URL="http://localhost:5173"
CORS_ORIGIN="http://localhost:5173"
